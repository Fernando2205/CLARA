# Copia este archivo como .env. Nunca expongas esta clave en VITE_* ni en React.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Voz natural de CLARA (texto a voz). Sin ELEVENLABS_API_KEY, /speak responde 503.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

FRONTEND_ORIGIN=http://localhost:5173
DATABASE_PATH=./clara.db
GENERATED_DIR=./generated
VOICE_CACHE_DIR=./voice_cache

# Opcionales: sin ellos el envío se simula y el demo no se interrumpe.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
REPORT_FROM_EMAIL=CLARA <reportes@tu-dominio.com>
